# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3006
NEXT_PUBLIC_WS_URL=ws://localhost:3006/ws

# Authentication
NEXT_PUBLIC_AUTH_TOKEN_KEY=biznavigate_auth_token

# Meta / WhatsApp Embedded Signup
NEXT_PUBLIC_META_APP_ID=your_meta_app_id_here
# Config ID for the Embedded Signup flow (from Meta App Dashboard > WhatsApp > Embedded Signup)
NEXT_PUBLIC_EMBEDDED_SIGNUP_CONFIG_ID=your_embedded_signup_config_id_here

# Feature Flags
NEXT_PUBLIC_ENABLE_CHATBOT=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
